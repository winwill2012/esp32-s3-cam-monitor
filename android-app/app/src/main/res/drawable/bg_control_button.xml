<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#442563EB">
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#BDD4FF"
                android:startColor="#F5FAFF" />
            <stroke
                android:width="1dp"
                android:color="#80FFFFFF" />
            <size
                android:width="64dp"
                android:height="64dp" />
        </shape>
    </item>
</ripple>
